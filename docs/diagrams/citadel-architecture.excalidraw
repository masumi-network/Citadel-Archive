      "locked": false,
      "text": "1  Claude Code SessionEnd hook\n     or git pre-push hook fires\n2  Distill session → note\n3  HTTPS POST, dataset omitted\n     (fail-silent, always exit 0)\n4  Lands in seat:{slug} node\n     (personal by default)\n5  Later promoted to Central\n     if it proves useful",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1  Claude Code SessionEnd hook\n     or git pre-push hook fires\n2  Distill session → note\n3  HTTPS POST, dataset omitted\n     (fail-silent, always exit 0)\n4  Lands in seat:{slug} node\n     (personal by default)\n5  Later promoted to Central\n     if it proves useful",
      "autoResize": true,
      "lineHeight": 1.15
    },

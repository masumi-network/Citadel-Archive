      "boundElements": null,
      "updated": 1784302058742,
      "link": null,
      "locked": false,
      "text": "1  Curate knowledge in seat node\n2  /api/promote → pending queue\n3  Admin approves / rejects\n4  Dual-write into Central —\n     the ONLY seat→Central path\n5  MCP tokens stay read-only\n     on Central (fail-closed)",
      "fontSize": 14,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1  Curate knowledge in seat node\n2  /api/promote → pending queue\n3  Admin approves / rejects\n4  Dual-write into Central —\n     the ONLY seat→Central path\n5  MCP tokens stay read-only\n     on Central (fail-closed)",
      "autoResize": true,
      "lineHeight": 1.15
    },
